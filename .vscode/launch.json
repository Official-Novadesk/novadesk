{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug build-mingw/novadesk.exe",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build-mingw/Debug/novadesk.exe",
            "args": ["--debug"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:\\msys64\\mingw64\\bin\\gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
